{
  "name": "proofrail",
  "private": true,
  "version": "0.2.0-rc.1",
  "description": "Deterministic evidence gating for AI-authored pull requests.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "governance:generate": "node scripts/governance/generate.mjs",
    "governance:check": "node scripts/validate-foundation.mjs",
    "governance:check-json": "node scripts/governance/verify-json-output.mjs",
    "governance:check-lf-checkout": "node scripts/governance/verify-lf-checkout.mjs",
    "clean-agent:validate": "node scripts/governance/validate-clean-agent-runs.mjs",
    "test:governance": "node --test tests/governance/*.test.mjs",
    "architecture:check": "node scripts/architecture/check-package-boundaries.mjs",
    "test:architecture": "node --test tests/architecture/*.test.mjs",
    "product:reason-codes": "node scripts/product/validate-reason-codes.mjs",
    "test:product-reason-codes": "node --test tests/product/*.test.mjs",
    "product:fixtures": "node scripts/product/run-product-fixtures.mjs",
    "product:fixture-inventory": "node scripts/product/render-product-fixture-inventory.mjs",
    "test:product-fixtures": "node --test tests/product-fixtures/*.test.mjs",
    "evidence-gate": "node packages/evidence-gate/src/cli.mjs",
    "evidence-gate:github": "node packages/evidence-gate/src/github-cli.mjs",
    "evidence-gate:demo": "node packages/evidence-gate/src/cli.mjs --input examples/evidence-gate/input.json",
    "test:evidence-gate": "node --test tests/evidence-gate/*.test.mjs",
    "test:trusted-config": "node --test tests/trusted-config/*.test.mjs",
    "test:verification-runner": "node --test tests/verification-runner/*.test.mjs",
    "test:release-orchestrator": "node --test tests/release-orchestrator/*.test.mjs",
    "proofrail-release": "node packages/evidence-gate/src/release-cli.mjs",
    "proofrail-release:fixture": "node examples/release/verify-fixture.mjs",
    "proofrail:prototype": "node packages/evidence-gate/src/prototype-cli.mjs",
    "test:market": "node --test tests/market/*.test.mjs",
    "test:public-site": "node --test tests/public-site/public-site.test.mjs",
    "static-evaluate": "node packages/static-evaluator/src/cli.mjs",
    "static-evaluate:demo": "node packages/static-evaluator/src/cli.mjs --input examples/static-evaluator/input.json",
    "test:static-evaluator": "node --test tests/static-evaluator/*.test.mjs",
    "typecheck:phase1": "tsc -p tsconfig.json",
    "test:kernel": "node --test packages/kernel/test/*.test.js",
    "validate:foundation": "node scripts/validate-foundation.mjs",
    "verify": "pnpm governance:check && pnpm governance:check-json && pnpm governance:check-lf-checkout && pnpm clean-agent:validate && pnpm test:governance && pnpm architecture:check && pnpm test:architecture && pnpm product:reason-codes && pnpm test:product-reason-codes && pnpm product:fixtures && pnpm product:fixture-inventory && pnpm test:product-fixtures && pnpm test:trusted-config && pnpm test:verification-runner && pnpm test:release-orchestrator && pnpm test:evidence-gate && pnpm test:market && pnpm test:public-site && pnpm proofrail-release:fixture && pnpm test:static-evaluator && pnpm typecheck:phase1 && pnpm test:kernel && git diff --check"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ajv": "^8.20.0",
    "typescript": "5.8.3"
  }
}
