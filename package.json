{
  "name": "proofrail",
  "private": true,
  "version": "0.1.0-phase1",
  "description": "Evidence control plane foundation for autonomous software changes.",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "governance:generate": "node scripts/governance/generate.mjs",
    "governance:check": "node scripts/validate-foundation.mjs",
    "governance:check-json": "node scripts/governance/verify-json-output.mjs",
    "test:governance": "node --test tests/governance/*.test.mjs",
    "evidence-gate": "node packages/evidence-gate/src/cli.mjs",
    "evidence-gate:github": "node packages/evidence-gate/src/github-cli.mjs",
    "evidence-gate:demo": "node packages/evidence-gate/src/cli.mjs --input examples/evidence-gate/input.json",
    "test:evidence-gate": "node --test tests/evidence-gate/*.test.mjs",
    "typecheck:phase1": "tsc -p tsconfig.json",
    "test:kernel": "node --test packages/kernel/test/*.test.js",
    "validate:foundation": "node scripts/validate-foundation.mjs",
    "verify": "pnpm governance:check && pnpm governance:check-json && pnpm test:governance && pnpm test:evidence-gate && pnpm typecheck:phase1 && pnpm test:kernel && git diff --check"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ajv": "^8.20.0",
    "typescript": "5.8.3"
  }
}
