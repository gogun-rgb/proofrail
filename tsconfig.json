{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "target": "ES2024",
    "types": ["node"]
  },
  "include": [
    "packages/contracts/src/**/*.d.ts",
    "packages/contracts/src/**/*.js",
    "packages/kernel/src/**/*.js",
    "packages/kernel/test/**/*.js"
  ]
}
