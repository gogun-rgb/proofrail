{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofrail.dev/schemas/harness-reason-codes.schema.json",
  "title": "Proofrail Foundation Harness Reason-Code Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "namespace",
    "prefix",
    "separation",
    "codes"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": "1" },
    "namespace": { "type": "string", "minLength": 1 },
    "prefix": { "const": "HARN_" },
    "separation": { "type": "string", "minLength": 1 },
    "codes": {
      "type": "array",
      "minItems": 1,
      "contains": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": { "const": "HARN_EMITTED_REASON_CODE_UNKNOWN" }
        }
      },
      "minContains": 1,
      "maxContains": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "summary", "remediation"],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^HARN_[A-Z0-9_]+$"
          },
          "summary": { "type": "string", "minLength": 1 },
          "remediation": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
