{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofrail.dev/schemas/product/evidence-contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "version", "authorizationEventId", "targetScopeId", "selectionProvenance", "requirements"],
  "properties": {
    "schemaVersion": { "const": "proofrail.evidence-contract.v1" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "authorizationEventId": { "type": "string", "minLength": 1 },
    "targetScopeId": { "type": "string", "minLength": 1 },
    "selectionProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "configurationId", "configurationVersion"],
      "properties": {
        "source": { "const": "TRUSTED_CONFIGURATION" },
        "configurationId": { "type": "string", "minLength": 1 },
        "configurationVersion": { "type": "string", "minLength": 1 }
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "targetScopeId", "requiredObserver", "factKey", "expectedValue"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "targetScopeId": { "type": "string", "minLength": 1 },
          "requiredObserver": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "version"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 }
            }
          },
          "factKey": { "type": "string", "minLength": 1 },
          "expectedValue": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" },
              { "type": "null" }
            ]
          }
        }
      }
    }
  }
}
