{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofrail.dev/schemas/product/policy.v2.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "version", "authorizationEventId", "targetScopeSelector", "evidenceContract", "requiredCheckPolicy", "reviewPolicy", "scopePolicy", "executionPolicy", "rules"],
  "properties": {
    "schemaVersion": { "const": "proofrail.policy.v2" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "authorizationEventId": { "type": "string", "minLength": 1 },
    "targetScopeSelector": { "const": "CURRENT_GITHUB_PULL_REQUEST" },
    "evidenceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "requiredCheckPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumReportedChecks", "requireAllReportedChecksSuccessful", "acceptedCheckRunConclusions", "acceptedStatusContextStates"],
      "properties": {
        "minimumReportedChecks": { "type": "integer", "minimum": 0, "maximum": 100 },
        "requireAllReportedChecksSuccessful": { "const": true },
        "acceptedCheckRunConclusions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["NEUTRAL", "SKIPPED", "SUCCESS"] }
        },
        "acceptedStatusContextStates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "const": "SUCCESS" }
        }
      }
    },
    "reviewPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumApprovals", "requireExactHeadApproval", "blockChangesRequested"],
      "properties": {
        "minimumApprovals": { "type": "integer", "minimum": 0, "maximum": 20 },
        "requireExactHeadApproval": { "const": true },
        "blockChangesRequested": { "const": true }
      }
    },
    "scopePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedPatternsRequired", "deniedPatternsTakePrecedence", "protectBaseConfigurationPath"],
      "properties": {
        "allowedPatternsRequired": { "const": true },
        "deniedPatternsTakePrecedence": { "const": true },
        "protectBaseConfigurationPath": { "const": ".proofrail/config.yml" }
      }
    },
    "executionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commandFailureMode", "requireReceiptForEveryStartedCommand", "requirePostVerificationHeadMatch"],
      "properties": {
        "commandFailureMode": { "const": "STOP_ON_FIRST_FAILURE" },
        "requireReceiptForEveryStartedCommand": { "const": true },
        "requirePostVerificationHeadMatch": { "const": true }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "condition", "verdict", "reasonCode"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "condition": {
            "enum": [
              "STALE_TARGET",
              "EXECUTION_IMPOSSIBLE",
              "SCOPE_PATH_DENIED",
              "UNTRUSTED_POLICY_CHANGE",
              "VERIFICATION_COMMAND_FAILED",
              "EXACT_HEAD_APPROVAL_MISSING",
              "MINIMUM_APPROVALS_MISSING",
              "CHANGES_REQUESTED_PRESENT",
              "REPORTED_CHECK_FAILED",
              "REQUIRED_EVIDENCE_MISSING"
            ]
          },
          "verdict": { "enum": ["REVISION_REQUIRED", "REJECTED", "BLOCKED"] },
          "reasonCode": { "type": "string", "pattern": "^PRF_[A-Z0-9_]+$" }
        }
      }
    }
  }
}
