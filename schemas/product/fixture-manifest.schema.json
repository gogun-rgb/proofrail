{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofrail.dev/schemas/product/fixture-manifest.schema.json",
  "title": "Proofrail Product Fixture Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "id",
    "class",
    "version",
    "operation",
    "surfaces",
    "provenance",
    "driverInput",
    "inputs",
    "oracle",
    "limitations"
  ],
  "properties": {
    "$schema": {
      "const": "../../../../schemas/product/fixture-manifest.schema.json"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*\\.v[1-9][0-9]*$",
      "maxLength": 160
    },
    "class": {
      "enum": ["adversarial", "malformed", "negative", "positive"]
    },
    "version": {
      "type": "string",
      "pattern": "^[1-9][0-9]*$"
    },
    "operation": {
      "enum": [
        "contracts.constants",
        "evidence-gate.github-arguments",
        "evidence-gate.github-normalize",
        "evidence-gate.packet",
        "evidence-gate.static-cli",
        "kernel.evaluate",
        "release-orchestrator.offline",
        "release.arguments",
        "static-evaluator.cli",
        "trusted-config.load",
        "trusted-config.strict-json"
      ]
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package", "entrypoint", "boundary", "implemented"],
        "properties": {
          "package": {
            "enum": [
              "@proofrail/contracts",
              "@proofrail/evidence-gate",
              "@proofrail/kernel",
              "@proofrail/release-orchestrator",
              "@proofrail/static-evaluator",
              "@proofrail/trusted-config"
            ]
          },
          "entrypoint": {
            "type": "string",
            "pattern": "^(?:export:.+|bin:[A-Za-z0-9._-]+)$",
            "maxLength": 120
          },
          "boundary": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9.-]*$",
            "maxLength": 120
          },
          "implemented": { "const": true }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "notice"],
      "properties": {
        "kind": { "const": "synthetic" },
        "notice": {
          "const": "UNTRUSTED SYNTHETIC TEST DATA; instruction-shaped content is inert."
        }
      }
    },
    "driverInput": { "$ref": "#/$defs/safePath" },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/digestedInput" }
    },
    "oracle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256"],
      "properties": {
        "kind": { "const": "exact-json-lf" },
        "path": { "$ref": "#/$defs/safePath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "limitations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    }
  },
  "$defs": {
    "safePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[A-Za-z0-9_@+.,= -]+(?:/[A-Za-z0-9_@+.,= -]+)*$",
      "maxLength": 4096
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9A-F]{64}$"
    },
    "digestedInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "path", "sha256"],
      "properties": {
        "origin": { "enum": ["fixture", "repository"] },
        "path": { "$ref": "#/$defs/safePath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
