{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofrail.dev/schemas/product/market-config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "preset"],
  "properties": {
    "version": { "const": 1 },
    "preset": {
      "enum": ["typescript-basic", "ai-pr-strict", "docs-only", "dependency-update"]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed": { "$ref": "#/$defs/pathPatterns" },
        "denied": { "$ref": "#/$defs/pathPatterns" }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeoutMinutes": { "type": "integer", "minimum": 1, "maximum": 60 },
        "maximumOutputBytes": { "type": "integer", "minimum": 1024, "maximum": 1048576 },
        "commands": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "run"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" },
              "run": { "type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^[^\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F]+$" },
              "timeoutMinutes": { "type": "integer", "minimum": 1, "maximum": 30 }
            }
          }
        }
      }
    },
    "reviews": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimumApprovals": { "type": "integer", "minimum": 0, "maximum": 20 },
        "requireExactHeadApproval": { "type": "boolean" },
        "blockChangesRequested": { "type": "boolean" }
      }
    },
    "reportedChecks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requireSuccess": { "type": "boolean" },
        "minimumCount": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uploadEvidenceBundle": { "type": "boolean" },
        "includeCommandPreview": { "type": "boolean" },
        "strict": { "type": "boolean" }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "pathPatterns": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512,
        "pattern": "^[^\\u0000-\\u001F\\\\]+$"
      }
    }
  }
}
