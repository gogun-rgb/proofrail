{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofrail.dev/schemas/product/policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "version", "authorizationEventId", "targetScopeId", "evidenceContract", "requiredCheckPolicy", "rules"],
  "properties": {
    "schemaVersion": { "const": "proofrail.policy.v1" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "authorizationEventId": { "type": "string", "minLength": 1 },
    "targetScopeId": { "type": "string", "minLength": 1 },
    "evidenceContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "requiredCheckPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumReportedChecks", "requireAllReportedChecksSuccessful", "acceptedCheckRunConclusions", "acceptedStatusContextStates"],
      "properties": {
        "minimumReportedChecks": { "type": "integer", "minimum": 1 },
        "requireAllReportedChecksSuccessful": { "const": true },
        "acceptedCheckRunConclusions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["NEUTRAL", "SKIPPED", "SUCCESS"] }
        },
        "acceptedStatusContextStates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "const": "SUCCESS" }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "predicate", "effect", "authority"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "predicate": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "evidenceRequirementId"],
            "properties": {
              "kind": { "enum": ["EVIDENCE_ABSENT", "EVIDENCE_PRESENT"] },
              "evidenceRequirementId": { "type": "string", "minLength": 1 }
            }
          },
          "effect": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "reasonCode"],
            "properties": {
              "kind": { "const": "DENY" },
              "reasonCode": { "type": "string", "minLength": 1 }
            }
          },
          "authority": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "policyId", "policyVersion"],
            "properties": {
              "source": { "const": "POLICY" },
              "policyId": { "type": "string", "minLength": 1 },
              "policyVersion": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
