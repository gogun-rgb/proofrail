{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proofrail.dev/schemas/product/trusted-configuration.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "version", "authorizationEventId", "issuerActorId", "releaseDeciderActorId", "independentReviewerActorId", "target", "observer", "claim", "declaredWriteScope", "policy", "evidenceContract", "executionBoundary", "kernel", "output"],
  "properties": {
    "schemaVersion": { "const": "proofrail.trusted-configuration.v1" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "authorizationEventId": { "type": "string", "minLength": 1 },
    "issuerActorId": { "type": "string", "minLength": 1 },
    "releaseDeciderActorId": { "type": "string", "minLength": 1 },
    "independentReviewerActorId": { "type": "string", "minLength": 1 },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "repository", "pullRequestNumber", "baseRefName", "baseSha", "headSha", "targetScopeId"],
      "properties": {
        "kind": { "const": "GITHUB_PULL_REQUEST" },
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "pullRequestNumber": { "type": "integer", "minimum": 1 },
        "baseRefName": { "type": "string", "minLength": 1 },
        "baseSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "headSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "targetScopeId": { "type": "string", "minLength": 1 }
      }
    },
    "observer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "sourceInputId"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "sourceInputId": { "type": "string", "minLength": 1 }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targetScopeId", "statement"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "targetScopeId": { "type": "string", "minLength": 1 },
        "statement": { "type": "string", "minLength": 1 }
      }
    },
    "declaredWriteScope": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "policy": { "$ref": "#/$defs/artifactReference" },
    "evidenceContract": { "$ref": "#/$defs/artifactReference" },
    "executionBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["githubRead", "githubWrite", "networkPolicy", "credentialPolicy", "targetCheckout", "targetRepositoryContentRead", "targetCommandExecution", "verificationCommandExecution", "modelExecution"],
      "properties": {
        "githubRead": { "const": true },
        "githubWrite": { "const": false },
        "networkPolicy": { "const": "GITHUB_READ_ONLY_VIA_INSTALLED_GH" },
        "credentialPolicy": { "const": "USE_EXISTING_GH_AUTHENTICATION_WITHOUT_INSPECTION_OR_PERSISTENCE" },
        "targetCheckout": { "const": false },
        "targetRepositoryContentRead": { "const": false },
        "targetCommandExecution": { "const": false },
        "verificationCommandExecution": { "const": false },
        "modelExecution": { "const": false }
      }
    },
    "kernel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputSchemaVersion", "bundleSchemaVersion", "engineVersion", "maximumInvocationCount"],
      "properties": {
        "inputSchemaVersion": { "const": "proofrail.kernel.input.phase1.v1" },
        "bundleSchemaVersion": { "const": "proofrail.evidence-bundle.phase1.v1" },
        "engineVersion": { "const": "0.1.0-phase1" },
        "maximumInvocationCount": { "const": 1 }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "format", "publicationBoundary"],
      "properties": {
        "kind": { "const": "FINALIZED_EVIDENCE_BUNDLE" },
        "format": { "const": "CANONICAL_JSON_LF" },
        "publicationBoundary": { "const": "EXISTING_STAGED_OUTPUT" }
      }
    }
  },
  "$defs": {
    "artifactReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "path", "sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9A-F]{64}$" }
      }
    }
  }
}
